# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Optional — enables the MOTHER agent loop.
# Telegram chat id (DM with you, usually) that mother listens to and replies in.
MOTHER_TELEGRAM_CHAT_ID=

# Optional — cwd mother is spawned in. Leave empty to use ~/.scuba/mother-home/
# (a dedicated dir scuba manages with a project-local .mcp.json registering the
# scuba MCP server). Don't set this to $HOME — that would pollute every claude
# session globally; scuba will refuse and fall back to the default anyway.
MOTHER_CWD=

# Optional — how long (ms) the TUI must stay in ready/idle after a turn before
# we post a "replied" screenshot to the bound chat. Lower = snappier, but
# higher chance of premature fires when claude blinks ready between tool
# calls. Default 1500.
TURN_END_DEBOUNCE_MS=
